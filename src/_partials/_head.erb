<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<% resource_title = strip_html(strip_newlines(title)) %>
<% page_description = description.to_s.empty? ? metadata.description : description %>
<% full_title = resource_title != "Index" ? "#{resource_title} | #{metadata.title}" : "#{metadata.title}: #{metadata.tagline}" %>
<title><%= full_title %></title>
<meta name="description" content="<%= page_description %>" />
<link rel="canonical" href="<%= resource.absolute_url %>" />
<% if resource.relative_url.end_with?("/") %>
<link rel="alternate" type="text/markdown" href="<%= resource.relative_url %>index.md" />
<% end %>
<% if resource.data.noindex %>
<meta name="robots" content="noindex, nofollow" />
<% end %>

<!-- Open Graph -->
<meta property="og:title" content="<%= full_title %>" />
<meta property="og:description" content="<%= page_description %>" />
<meta property="og:url" content="<%= resource.absolute_url %>" />
<meta property="og:site_name" content="<%= metadata.title %>" />
<meta property="og:type" content="<%= resource.data.layout == "post" ? "article" : "website" %>" />
<meta property="og:image" content="<%= site.config.url %>/images/og-image.png" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<%= full_title %>" />
<meta name="twitter:description" content="<%= page_description %>" />
<meta name="twitter:image" content="<%= site.config.url %>/images/og-image.png" />

<link rel="stylesheet" href="<%= asset_path :css %>" data-turbo-track="reload" />
<script src="<%= asset_path :js %>" defer data-turbo-track="reload"></script>
<script src="https://kit.fontawesome.com/347397420b.js" crossorigin="anonymous" data-turbo-track="reload"></script>
<%= live_reload_dev_js %>
